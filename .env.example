# Canvas credentials
#
# For UCI Canvas, use:
# CANVAS_BASE_URL=https://canvas.eee.uci.edu
CANVAS_BASE_URL=https://canvas.eee.uci.edu

# Canvas personal access token.
# Create one in Canvas:
# Account -> Settings -> Approved Integrations -> New Access Token
CANVAS_ACCESS_TOKEN=your_canvas_access_token

# Optional advanced settings. Most users do not need these.
# CANVAS_DOWNLOAD_DIR=/tmp/canvas-mcp-downloads
# CANVAS_MAX_PAGES=25
