# Canvas credentials
#
# CANVAS_BASE_URL is your school's Canvas website.
# For UCI Canvas, use https://canvas.eee.uci.edu.
CANVAS_BASE_URL=https://canvas.eee.uci.edu

# CANVAS_ACCESS_TOKEN is not your username or password.
# To create it:
# 1. Open CANVAS_BASE_URL in your browser.
# 2. Log in with your normal school Canvas/SSO username and password.
# 3. Go to Account -> Settings -> Approved Integrations.
# 4. Click New Access Token.
# 5. Copy the generated token and paste it here.
CANVAS_ACCESS_TOKEN=paste_your_canvas_access_token_here

# Optional advanced settings. Most users do not need these.
# CANVAS_DOWNLOAD_DIR=/tmp/canvas-mcp-downloads
# CANVAS_MAX_PAGES=25
