# Canvas credentials
#
# CANVAS_BASE_URL is your school's Canvas website.
# Example for UCI Canvas: https://canvas.eee.uci.edu
CANVAS_BASE_URL=your_canvas_address

# Browser/Duo login mode, similar to a Gradescope-style MCP.
# CANVAS_EMAIL can be your username, school email, or whatever your
# Canvas/SSO login page expects.
CANVAS_AUTH_MODE=browser
CANVAS_EMAIL=your_username_or_email
CANVAS_PASSWORD=your_password

# canvas-mcp-login saves the browser session here after you approve Duo.
CANVAS_STORAGE_STATE=.canvas-storage-state.json

# Alternative API-token mode. If this is set, it takes priority over browser mode.
# CANVAS_ACCESS_TOKEN=paste_your_canvas_access_token_here

# Optional advanced settings. Most users do not need these.
# By default, downloads are saved under ./canvas-mcp-downloads in the directory
# where the MCP server is started. You can override that here.
# CANVAS_DOWNLOAD_DIR=/Users/yourname/Downloads/canvas-mcp-downloads
# CANVAS_MAX_PAGES=25

# Optional Gradescope bridge. Use this when a Canvas assignment says the real
# prompt or submission is on Gradescope. If gradescope-mcp is at ~/gradescope-mcp,
# GRADESCOPE_MCP_PATH can be omitted.
# GRADESCOPE_MCP_PATH=/Users/yourname/gradescope-mcp
# GRADESCOPE_EMAIL=your_email@example.com
# GRADESCOPE_PASSWORD=your_password
