# Your Canvas instance. For UCI Canvas this is commonly:
# CANVAS_BASE_URL=https://canvas.eee.uci.edu
CANVAS_BASE_URL=https://canvas.example.edu

# Canvas personal access token:
# Account -> Settings -> Approved Integrations -> New Access Token
CANVAS_ACCESS_TOKEN=replace_me

# Optional: where assignment workspaces and downloaded files are written.
CANVAS_DOWNLOAD_DIR=/tmp/canvas-mcp-downloads

# Optional: safety cap for paginated API calls.
CANVAS_MAX_PAGES=25
